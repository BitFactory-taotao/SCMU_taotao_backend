<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bit.scmu_taotao.mapper.TGoodsImageMapper">

    <resultMap id="BaseResultMap" type="com.bit.scmu_taotao.entity.TGoodsImage">
            <id property="imageId" column="image_id" />
            <result property="goodsId" column="goods_id" />
            <result property="imageUrl" column="image_url" />
            <result property="sort" column="sort" />
            <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        image_id,goods_id,image_url,sort,create_time,is_delete
    </sql>

    <!-- 基础查询 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM t_goods_image
        <where>
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.bit.scmu_taotao.entity.TGoodsImage" useGeneratedKeys="true" keyProperty="imageId">
        INSERT INTO t_goods_image (
            goods_id, image_url, sort, create_time, update_time, is_delete
        ) VALUES (
            #{goodsId},
            #{imageUrl},
            #{sort},
            #{createTime},
            #{updateTime},
            #{isDelete}
        )
    </insert>

    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        SELECT <include refid="Base_Column_List"/>
        FROM t_goods_image
        WHERE image_id = #{imageId}
    </select>

    <!-- 根据 ID 删除 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM t_goods_image WHERE image_id = #{imageId}
    </delete>

    <!-- 批量删除 -->
    <delete id="deleteBatchIds" parameterType="java.util.Collection">
        DELETE FROM t_goods_image WHERE image_id IN
        <foreach collection="collection" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
